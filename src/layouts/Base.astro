---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/style.css';

interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description = 'Portal de referência em uroginecologia para profissionais de saúde.',
  canonicalUrl,
  ogTitle,
  ogDescription,
} = Astro.props;

const siteTitle = title.includes('Uroginecologia') ? title : `${title} | Uroginecologia em Dia`;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">

    <!-- PWA Configuration -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#1e40af">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXXXX');
    </script>

    <!-- Meta Tags SEO -->
    <meta name="description" content={description}>
    <meta name="keywords" content="uroginecologia, incontinência urinária, prolapso genital, assoalho pélvico, protocolos clínicos, FEBRASGO">
    <meta name="author" content="Uroginecologia em Dia">

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    {canonicalUrl && <meta property="og:url" content={canonicalUrl}>}
    <meta property="og:title" content={ogTitle || siteTitle}>
    <meta property="og:description" content={ogDescription || description}>

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:title" content={ogTitle || siteTitle}>
    <meta property="twitter:description" content={ogDescription || description}>

    <title>{siteTitle}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico">

    <!-- Feather Icons -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <script src="https://cdn.jsdelivr.net/npm/feather-icons/dist/feather.min.js" async></script>

    <slot name="head" />
</head>
<body class="bg-uro-cinza font-sans">
    <!-- Skip to main content (acessibilidade) -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 bg-uro-azul text-white p-4 z-50">
        Pular para conteúdo principal
    </a>

    <Header />

    <slot />

    <Footer />

    <!-- Core Scripts -->
    <script is:inline src="/assets/js/constants.js"></script>
    <script is:inline src="/assets/js/utils.js"></script>
    <script is:inline src="/assets/js/common.js"></script>

    <slot name="scripts" />
</body>
</html>
