<!-- Footer -->
<footer class="bg-uro-azul_escuro text-white py-12">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            <div>
                <h3 class="text-lg font-bold mb-4">Uroginecologia em Dia</h3>
                <p class="mb-4">Portal de referência em conhecimento uroginecológico para profissionais de saúde.</p>
                <div class="flex space-x-4">
                    <a href="#" class="hover:text-uro-azul_claro" aria-label="Instagram"><i data-feather="instagram"></i></a>
                    <a href="#" class="hover:text-uro-azul_claro" aria-label="Facebook"><i data-feather="facebook"></i></a>
                    <a href="#" class="hover:text-uro-azul_claro" aria-label="LinkedIn"><i data-feather="linkedin"></i></a>
                </div>
            </div>
            <div>
                <h4 class="text-md font-bold mb-4">Entre em Contato</h4>
                <address class="not-italic">
                    <p class="mb-2"><i data-feather="mail" class="inline mr-2 w-4 h-4"></i> contato@uroginecologiaemdia.com.br</p>
                    <p><i data-feather="phone" class="inline mr-2 w-4 h-4"></i> (11) 99999-9999</p>
                </address>
            </div>
            <div>
                <h4 class="text-md font-bold mb-4">Links Rápidos</h4>
                <ul class="space-y-2">
                    <li><a href="/" class="hover:text-uro-azul_claro">Página Inicial</a></li>
                    <li><a href="/sobre/" class="hover:text-uro-azul_claro">Sobre Nós</a></li>
                    <li><a href="/contato/" class="hover:text-uro-azul_claro">Fale Conosco</a></li>
                </ul>
            </div>
            <div>
                <h4 class="text-md font-bold mb-4">Seções</h4>
                <ul class="space-y-2">
                    <li><a href="/artigos/" class="hover:text-uro-azul_claro">Artigos Resumidos</a></li>
                    <li><a href="/protocolos/" class="hover:text-uro-azul_claro">Protocolos</a></li>
                    <li><a href="/noticias/" class="hover:text-uro-azul_claro">Notícias</a></li>
                    <li><a href="/eventos/" class="hover:text-uro-azul_claro">Eventos</a></li>
                </ul>
            </div>
        </div>
        <div class="border-t border-uro-azul mt-8 pt-8 text-sm text-center">
            <p>&copy; {new Date().getFullYear()} Uroginecologia em Dia. Todos os direitos reservados.</p>
